# Copy to .env only to switch registry or pin different tags.
# With no .env, `docker compose up` pulls all images from GHCR (public, no login).

# Registry for all services: default is GHCR. Uncomment for AWS ECR Public.
# REGISTRY=public.ecr.aws/protegrity-ai-developer-edition

# Image tags (must exist on the chosen registry)
#PTY_POSTGRES_TAG=latest
#ANONYMIZATION_TAG=2.0.0-6-6c8dca25-dev
