# Copy to .env only if you want to switch registry or pin different tags.
# With no .env, `docker compose up` pulls from GHCR (public, no login).

# Registry: default is GHCR. Uncomment for AWS ECR Public instead.
# REGISTRY=public.ecr.aws/protegrity-ai-developer-edition

# Image tags (must exist on the chosen registry)
# PATTERN_TAG=2.0.0.320.59776828
# CONTEXT_TAG=2.0.0.242.5041932c
# CLASSIFICATION_TAG=2.0.0.374.8047721c
