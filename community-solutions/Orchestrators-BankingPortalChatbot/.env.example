# ──────────────────────────────────────────────────────────────────────
# Banking Portal Chatbot — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────────

# Protegrity Developer Edition credentials
# Sign up at: https://www.protegrity.com/developers/dev-edition-api
DEV_EDITION_EMAIL=your-email@company.com
DEV_EDITION_PASSWORD=your-password
DEV_EDITION_API_KEY=your-api-key

# Protegrity service endpoints (defaults — change if containers run elsewhere)
CLASSIFY_URL=http://localhost:8580/pty/data-discovery/v1.1/classify
SGR_URL=http://localhost:8581/pty/semantic-guardrail/v1.1/conversations/messages/scan

# Protegrity REST API for user-based detokenization (Gate 2)
PROTEGRITY_HOST=http://localhost:8580
DETOKENIZE_URL=http://localhost:8580/pty/data-discovery/v1.1/unprotect
PROTEGRITY_API_TIMEOUT=60

# ── Local LLM stack (Ollama) ─────────────────────────────────────────
LLM_PROVIDER=ollama

# Cloud LLM API keys (optional — can also be set via Technical App dashboard)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# XAI_API_KEY=xai-...

# Ollama — CPU default; GPU model used when NVIDIA is detected or OLLAMA_GPU_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11435
OLLAMA_CPU_MODEL=qwen3.5:0.8b
OLLAMA_GPU_MODEL=qwen3.5:4b
OLLAMA_GPU_ENABLED=false
OLLAMA_ACTIVE_MODEL=qwen3.5:0.8b

# Optional explicit model override for all providers
# LLM_MODEL=qwen3.5:0.8b

# Orchestrator default (langgraph for pipeline demos)
ORCHESTRATOR=langgraph

# App ports (defaults)
# TECH_PORT=5002
# BUSINESS_PORT=5003
# OBSERVER_PORT=5004
